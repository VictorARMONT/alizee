# ALIZEE — .env.example
# Copiar a .env.local y llenar con valores reales
# NO commitear .env.local (está en .gitignore)
# Guía detallada: docs/SETUP.md

# ── Cifrado de ficha (PII) — OBLIGATORIA en producción ──
# Generar: openssl rand -base64 32
FICHA_SECRET=

# ── Analytics ──
# GA4 — obtener de analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Meta Pixel — obtener de business.facebook.com > Events Manager
NEXT_PUBLIC_META_PIXEL_ID=

# ── WhatsApp y URL base ──
# Número destino para checkout (código país + número, sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=523349571689
NEXT_PUBLIC_BASE_URL=https://alizee.mx

# ── Google Maps (autocompletado de dirección) ──
# Restringir por dominio en GCP (ver docs/SETUP.md)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Brevo (email marketing) — generar en app.brevo.com/account/api ──
BREVO_API_KEY=xxxxxxxxxxxxxxxxxxx
BREVO_LIST_ID=123456

# ── Rate limiting (Upstash Redis / Vercel KV) ──
# Provisionar en Vercel > Storage. Inyecta estas vars automáticamente.
# (alternativa Upstash directo: UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Pagos CLIP (pendiente) ──
CLIP_API_KEY=
